# LJS runtime environment variables
# Most application settings are configured through the setup wizard,
# config/settings.yaml, or config/categories/<category_id>.yaml.

# Server binding
LJS_PORT=8088
LJS_HOST=0.0.0.0
LJS_ACCESS_LOGS=quiet

# Web auth token signing secret. Set this in production.
LJS_WEB_SECRET=change-me-in-production-random-secret

# Development only. run.sh/run.bat set this automatically for local smoke runs.
LJS_ALLOW_INSECURE_DEV=1

# Configure LLM providers, Jackett, web-search APIs, category paths, and optional
# integrations in the UI or YAML files rather than through environment variables.
